local function aw()
    local char = i.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    if getgenv().Config.NoClip then 
        for _, aB in pairs(char:GetDescendants()) do 
            if aB:IsA("BasePart") then aB.CanCollide=false end 
        end 
    end

    if getgenv().Config.AntiFling then
        for _, p in pairs(c:GetPlayers()) do
            if p ~= i and p.Character then
                for _, v in pairs(p.Character:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                        v.Velocity = Vector3.new(0,0,0)
                        v.RotVelocity = Vector3.new(0,0,0)
                    end
                end
            end
        end
        root.RotVelocity = Vector3.new(0,0,0)
    end

    if getgenv().Config.Fly then
        local bg = root:FindFirstChild("IY_Gyro") or Instance.new("BodyGyro", root)
        local bv = root:FindFirstChild("IY_Vel") or Instance.new("BodyVelocity", root)
        bg.Name = "IY_Gyro"; bv.Name = "IY_Vel"
        bg.P = 9e4
        bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.cframe = workspace.CurrentCamera.CFrame
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        if hum.MoveDirection.Magnitude > 0 then
            local cam = workspace.CurrentCamera.CFrame
            local moveDir = hum.MoveDirection
            local look = cam.LookVector
            local right = cam.RightVector
            local forwardAmount = moveDir:Dot(cam.LookVector)
            local rightAmount = moveDir:Dot(cam.RightVector)
            bv.velocity = (look * forwardAmount * 50) + (right * rightAmount * 50)
            if math.abs(look.Y) > 0.3 then
                bv.velocity = bv.velocity + Vector3.new(0, look.Y * forwardAmount * 50, 0)
            end
        else
            bv.velocity = Vector3.new(0, 0, 0)
        end
        hum.PlatformStand = true
    else
        if root:FindFirstChild("IY_Gyro") then root.IY_Gyro:Destroy() end
        if root:FindFirstChild("IY_Vel") then root.IY_Vel:Destroy() end
        hum.PlatformStand = false
    end

    if getgenv().Config.AntiStuck then
        if hum.Sit then 
            hum.Sit = false 
            hum.Jump = true 
            hum:ChangeState(Enum.HumanoidStateType.Jumping) 
        end
        local currentState = hum:GetState()
        if currentState == Enum.HumanoidStateType.FallingDown or currentState == Enum.HumanoidStateType.PlatformStanding then
            if not getgenv().Config.Fly then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end

    if getgenv().Config.AutoJump and hum.FloorMaterial ~= Enum.Material.Air then 
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

if _G.MainLoop then _G.MainLoop:Disconnect() end
_G.MainLoop = h.Stepped:Connect(aw)

task.spawn(function()
    while true do 
        if getgenv().Config.TeleportLoop and i.Character and i.Character:FindFirstChild("HumanoidRootPart") then 
            local p=getgenv().Config.TeleportPoint;
            i.Character.HumanoidRootPart.CFrame=CFrame.new(p.x,p.y,p.z)
        end;
        local av=getgenv().Config.TeleportDelay;
        if av and av>0 then task.wait(av) else h.Heartbeat:Wait() end 
    end 
end)
