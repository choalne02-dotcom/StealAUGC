if getgenv().AfkForFreeUGC_bwush then return end
getgenv().AfkForFreeUGC_bwush = true

--===[ QueueOnTeleport Loader ]===--
local QueueOnTeleport = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
local SCRIPT_URL = "https://raw.githubusercontent.com/QuangTrinh1009200303012007/RobloxUGC_Scripts/refs/heads/main/AfkForFreeUGC_bwush"

-- Biến kiểm soát việc có cho phép Rejoin hay không
local allowRejoin = true 

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local player = game.Players.LocalPlayer
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")

-- 1. Hàm kiểm tra số lượng người và quyết định có Rejoin hay không
local function CheckServerSecurity()
    if #Players:GetPlayers() >= 2 then
        allowRejoin = false -- Vô hiệu hóa tính năng tự động quay lại
        player:Kick("\n[BẢO MẬT CAO]\nPhát hiện server có " .. #Players:GetPlayers() .. " người.\nDừng Rejoin để bảo vệ tài khoản.")
    end
end

-- Chạy kiểm tra ngay lập tức và khi có người mới vào
CheckServerSecurity()
Players.PlayerAdded:Connect(CheckServerSecurity)

-- 2. Thực hiện Teleport đến vị trí chỉ định (Nếu chưa bị kick)
task.spawn(function()
    local targetPos = Vector3.new(741, 256, -329)
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    hrp.CFrame = CFrame.new(targetPos)
    
    -- Chờ ổn định vị trí
    local count = 0
    repeat
        task.wait(0.1)
        hrp.CFrame = CFrame.new(targetPos)
        count = count + 1
    until (hrp.Position - targetPos).Magnitude < 5 or count > 20
end)

-- 3. Logic Rejoin
local function RejoinLogic()
    -- Chỉ thực hiện Rejoin nếu biến allowRejoin vẫn là true
    if not allowRejoin then 
        print("Rejoin bị chặn do phát hiện server không an toàn.")
        return 
    end

    if game.PrivateServerId ~= "" then
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

-- Tự động gọi Rejoin khi mất kết nối hoặc bị Kick
GuiService.ErrorMessageChanged:Connect(function()
    if allowRejoin then
        task.wait(0.1)
        RejoinLogic()
    end
end)

-- 4. THỰC HIỆN KICK ĐỂ REJOIN (Chỉ thực hiện nếu server an toàn - 1 người)
task.wait(1.5) -- Đợi một chút để hàm kiểm tra người (CheckServerSecurity) kịp chạy
if allowRejoin then
    player:Kick("Đang Rejoin về Server Riêng để kích hoạt script...")
end
