if getgenv().AfkForFreeUGC_bwush then return end
getgenv().AfkForFreeUGC_bwush = true

--===[ QueueOnTeleport Loader ]===--
local QueueOnTeleport = queue_on_teleport or syn.queue_on_teleport
local SCRIPT_URL = "https://raw.githubusercontent.com/QuangTrinh1009200303012007/RobloxUGC_Scripts/refs/heads/main/AfkForFreeUGC_bwush"

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

-- Đợi Game Load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local player = game.Players.LocalPlayer
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")

-- 1. TÍNH NĂNG MỚI: Văng game nếu server có từ 2 người trở lên
local function CheckAndKickIfPeople()
    if #Players:GetPlayers() >= 2 then
        player:Kick("\n[BẢO MẬT]\nPhát hiện có người lạ trong server!\nĐã tự thoát để an toàn.")
    end
end
CheckAndKickIfPeople()
Players.PlayerAdded:Connect(CheckAndKickIfPeople)

-- 2. Thực hiện Teleport đến vị trí chỉ định
local targetPos = Vector3.new(741, 259, -329)
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

hrp.CFrame = CFrame.new(targetPos)

-- Chờ ổn định vị trí
repeat
    task.wait()
    hrp.CFrame = CFrame.new(targetPos)
until (hrp.Position - targetPos).Magnitude < 5

task.wait() -- Đợi thêm 2 giây cho chắc chắn

-- 3. Hàm Rejoin ưu tiên Server Riêng Tư
local function RejoinLogic()
    if game.PrivateServerId ~= "" then
        -- Đây là lệnh quan trọng nhất để giữ bạn ở Server Riêng
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        -- Nếu không có server riêng thì vào server thường
        TeleportService:Teleport(game.PlaceId, player)
    end
end

-- Tự động gọi Rejoin khi bị Kick (Bao gồm cả lệnh Kick ở bước 4)
game:GetService("GuiService").ErrorMessageChanged:Connect(function()
    task.wait()
    RejoinLogic()
end)

-- 4. THỰC HIỆN KICK ĐỂ REJOIN (Như bạn yêu cầu)
player:Kick("Đang Rejoin về Server Riêng để kích hoạt script...")
