tx.Parent = sg

--===[ Logic Chính ]===--
local a = game:GetService("ReplicatedStorage")
local d = lp

for i = 60, 0, -1 do
    tx.Text = "Waiting: " .. i .. "s"
    task.wait(1)
end

tx.Text = "Executing..."
task.wait(0.5)
sg:Destroy()

