    end
end

local function g()
    local x = "rbxthumb://type=AvatarHeadShot&id=" .. U.UserId .. "&w=100&h=100"
    for _, v in pairs(W:GetChildren()) do
        if v.Name:match("^Tycoon") then
            local o = v:FindFirstChild("OwnerGui", true)
            if o and o:FindFirstChild("Avatar") and o.Avatar.Image == x then
                return v
            end
        end
    end
    return nil
end

