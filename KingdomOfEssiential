local enoughMoney = false

-- LOOP TYCOON: Khôi phục logic so sánh tiền chuẩn của bạn
task.spawn(function()
    while task.wait(0.1) do
        if a then
            local t = g()
            if t then
                i.Text = "Scanning: " .. t.Name
                local currentCoins = parse(U.PlayerGui.HUD.LeftContainer.Currencies.Coins.Amount.Text)
                
                for _, v in pairs(t:GetChildren()) do
                    if v.Name:match("^Button_") and not v.Name:match("Upgrade") then
                        local tGui = v:FindFirstChild("TitleGui")
                        local isLocked = false
                        
                        if tGui and tGui:FindFirstChild("Lock") and tGui.Lock.Visible == true then
                            isLocked = true
                        end
                        
                        if not isLocked and tGui and tGui:FindFirstChild("Cost") then
                            local costValue = parse(tGui.Cost.Amount.Text)
                            
                            -- Logic so sánh tiền: Teleport nếu đủ, cập nhật enoughMoney
                            if currentCoins >= costValue then
                                enoughMoney = true
                                local p = v:IsA("BasePart") and v or v:FindFirstChildWhichIsA("BasePart", true)
                                if p then
                                    tp(p.CFrame)
                                    break
                                end
                            else
                                enoughMoney = false
                            end
                        end
                    end
                end
            end
        end
    end
end)

