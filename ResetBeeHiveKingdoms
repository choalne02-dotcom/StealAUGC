--===[ QueueOnTeleport Loader ]===--
local QueueOnTeleport = queue_on_teleport or syn.queue_on_teleport
local SCRIPT_URL = "https://raw.githubusercontent.com/choalne02-dotcom/StealAUGC/refs/heads/main/ResetBeeHiveKingdoms"

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

local RS = game:GetService("ReplicatedStorage")
local TS = game:GetService("TeleportService")
local GS = game:GetService("GuiService")
local PL = game:GetService("Players")

local lp = PL.LocalPlayer
local character = lp.Character or lp.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

--// Nhập mã Codes
local remoteCode = RS:WaitForChild("Remotes"):WaitForChild("EnterCode")
local codes = {"1KLikes", "3GYAY", "TestCode3", "Launch", "BIG", "JoinGroup", "StoryTime", "Dragon", "Enchanted", "Rainbows", "Sunshine"}

for _, c in ipairs(codes) do
    remoteCode:FireServer(c)
    task.wait(0.1)
end

--// Di chuyển và sử dụng Item
hrp.CFrame = CFrame.new(-51, 4, 144)
task.wait(1)

for i = 1, 5 do
    RS:WaitForChild("Remotes"):WaitForChild("UseItem"):FireServer({"UGC Seedling", {}})
    task.wait(0)
end

--// Tự động thu thập (Touch)
for _, v in pairs(workspace:GetDescendants()) do
    if v:IsA("TouchTransmitter") then
        local p = v.Parent
        if p:IsA("BasePart") then
            p.CanCollide = false
            p.Transparency = 0.5
            p.CFrame = hrp.CFrame
            firetouchinterest(hrp, p, 0)
            task.wait()
            firetouchinterest(hrp, p, 1)
        end
    end
end

--// Xử lý lỗi hệ thống (Nếu có bảng lỗi sẽ tự rejoin)
GS.ErrorMessageChanged:Connect(function()
    task.wait()
    TS:Teleport(game.PlaceId, lp)
end)

---// TÍNH NĂNG MỚI: TỰ ĐỘNG REJOIN SAU 10 GIÂY //---
task.delay(10, function()
    print("Đã hết 10 giây, đang chuẩn bị Rejoin...")
    TS:Teleport(game.PlaceId, lp)
end)

