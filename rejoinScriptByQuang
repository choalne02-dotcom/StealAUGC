local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local VirtualUser = game:GetService("VirtualUser")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local FILENAME = "S_Scripts_Config.json"

-- Hàm kiểm tra môi trường executor (Delta/Fluxus/v.v)
local is_file = isfile or function() return false end
local read_file = readfile or function() return "" end
local write_file = writefile or function() end

local function LoadConfig()
    local default = {
        AntiAFK = true,
        AutoRejoin = true,
        AutoJump = false,
        AntiStuck = true,
        TeleportLoop = false,
        TeleportPoint = {x = 0, y = 100, z = 0},
        TeleportDelay = 0.5,
        Fly = false,
        NoClip = false,
        RejoinSource = "https://raw.githubusercontent.com/choalne02-dotcom/StealAUGC/refs/heads/main/rejoinScriptByQuang",
        ExecuteThisScript = "https://pastefy.app/smxOpGnI/raw"
    }
    
    if is_file(FILENAME) then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, read_file(FILENAME))
        if success and type(decoded) == "table" then 
            for k, v in pairs(decoded) do default[k] = v end
        end
    end
    getgenv().Config = default
end

local function SaveConfig()
    pcall(function()
        write_file(FILENAME, HttpService:JSONEncode(getgenv().Config))
    end)
end

LoadConfig()

----------------------------------------------------------------
-- GIAO DIỆN (UI)
----------------------------------------------------------------
local function CreateUI()
    if CoreGui:FindFirstChild("S_ScriptUI") then CoreGui.S_ScriptUI:Destroy() end
    
    local sg = Instance.new("ScreenGui", CoreGui)
    sg.Name = "S_ScriptUI"
    
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 250, 0, 400)
    main.Position = UDim2.new(0, 20, 0.5, -200)
    main.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    main.BorderSizePixel = 0
    main.Active = true
    main.Draggable = true

    local scroll = Instance.new("ScrollingFrame", main)
    scroll.Size = UDim2.new(1, -10, 1, -45)
    scroll.Position = UDim2.new(0, 5, 0, 40)
    scroll.BackgroundTransparency = 1
    scroll.CanvasSize = UDim2.new(0, 0, 0, 650)
    scroll.ScrollBarThickness = 3

    local list = Instance.new("UIListLayout", scroll)
    list.Padding = UDim.new(0, 5)

    local function AddToggle(text, configKey)
        local btn = Instance.new("TextButton", scroll)
        btn.Size = UDim2.new(1, -10, 0, 30)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        local function UpdateBtn()
            btn.Text = text .. ": " .. (getgenv().Config[configKey] and "ON" or "OFF")
            btn.BackgroundColor3 = getgenv().Config[configKey] and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(231, 76, 60)
        end
        btn.MouseButton1Click:Connect(function()
            getgenv().Config[configKey] = not getgenv().Config[configKey]
            SaveConfig()
            UpdateBtn()
        end)
        UpdateBtn()
    end

    local function AddInput(label, configKey, isNumber)
        local lab = Instance.new("TextLabel", scroll)
        lab.Size = UDim2.new(1, -10, 0, 20)
        lab.Text = "  " .. label
        lab.TextColor3 = Color3.fromRGB(200, 200, 200)
        lab.BackgroundTransparency = 1
        lab.TextXAlignment = Enum.TextXAlignment.Left
        lab.TextSize = 11

        local box = Instance.new("TextBox", scroll)
        box.Size = UDim2.new(1, -10, 0, 30)
        box.Text = tostring(getgenv().Config[configKey])
        box.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        box.TextColor3 = Color3.fromRGB(255, 255, 255)
        box.ClearTextOnFocus = false
        
        box.FocusLost:Connect(function()
            local val = box.Text
            if isNumber then val = tonumber(val) or getgenv().Config[configKey] end
            getgenv().Config[configKey] = val
            SaveConfig()
        end)
    end

    local t = Instance.new("TextLabel", main)
    t.Size = UDim2.new(1, 0, 0, 35)
    t.Text = "S-SCRIPTS V2 (FIXED)"
    t.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    t.TextColor3 = Color3.fromRGB(255, 255, 255)
    t.Font = Enum.Font.GothamBold

    AddToggle("Anti AFK", "AntiAFK")
    AddToggle("Auto Rejoin", "AutoRejoin")
    AddToggle("Auto Jump", "AutoJump")
    AddToggle("Anti Stuck", "AntiStuck")
    AddToggle("Fly Mode", "Fly")
    AddToggle("No Clip", "NoClip")
    AddToggle("Teleport Loop", "TeleportLoop")
    
    AddInput("TP Delay (Seconds)", "TeleportDelay", true)
    
    local setPos = Instance.new("TextButton", scroll)
    setPos.Size = UDim2.new(1, -10, 0, 35)
    setPos.Text = "SAVE CURRENT POS"
    setPos.BackgroundColor3 = Color3.fromRGB(52, 152, 219)
    setPos.Font = Enum.Font.GothamBold
    setPos.MouseButton1Click:Connect(function()
        if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local pos = lp.Character.HumanoidRootPart.Position
            getgenv().Config.TeleportPoint = {x = pos.X, y = pos.Y, z = pos.Z}
            SaveConfig()
        end
    end)

    AddInput("Rejoin Source URL", "RejoinSource", false)
    AddInput("Execute Script URL", "ExecuteThisScript", false)
end

CreateUI()

