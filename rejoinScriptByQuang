-- Tự rejoin khi bị kick hoặc lỗi
if getgenv().Config.AutoRejoin then
    local queue_teleport = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
    if queue_teleport then
        pcall(function() 
            queue_teleport("loadstring(game:HttpGet('"..getgenv().Config.RejoinSource.."'))()")
            queue_teleport("loadstring(game:HttpGet('"..getgenv().Config.ExecuteThisScript.."'))()")
        end)
    end
    GuiService.ErrorMessageChanged:Connect(function()
        task.wait(1)
        TeleportService:Teleport(game.PlaceId, lp)
    end)
end

-- Chống AFK
lp.Idled:Connect(function()
    if getgenv().Config.AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- Vòng lặp chính xử lý nhân vật
local function handleCharacterLogic()
    local char = lp.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")

        if getgenv().Config.AntiStuck and hum.Sit then hum.Jump = true end
        if getgenv().Config.AutoJump and hum.FloorMaterial ~= Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        
        if getgenv().Config.AntiStuck then
            local state = hum:GetState()
            if state == Enum.HumanoidStateType.FallingDown or state == Enum.HumanoidStateType.PlatformStanding then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end

        if getgenv().Config.NoClip then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end

        if getgenv().Config.Fly and hrp then
            local v = hrp:FindFirstChild("S_Fly") or Instance.new("BodyVelocity", hrp)
            v.Name = "S_Fly"
            v.Velocity = Vector3.new(0, 0, 0)
            v.MaxForce = Vector3.new(0, 9e9, 0)
        elseif hrp and hrp:FindFirstChild("S_Fly") then
            hrp.S_Fly:Destroy()
        end
    end
end

if _G.MainLoop then _G.MainLoop:Disconnect() end
_G.MainLoop = RunService.RenderStepped:Connect(handleCharacterLogic)

-- Vòng lặp Teleport
task.spawn(function()
    while true do
        if getgenv().Config.TeleportLoop and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local p = getgenv().Config.TeleportPoint
            lp.Character.HumanoidRootPart.CFrame = CFrame.new(p.x, p.y, p.z)
        end
        task.wait(getgenv().Config.TeleportDelay or 0.5)
    end
end)
