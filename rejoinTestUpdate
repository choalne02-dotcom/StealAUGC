local is_file = isfile or function() return false end
local read_file = readfile or function() return "" end
local write_file = writefile or function() end

-- Chờ game load hoàn toàn trước khi tiếp tục
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local function LoadConfig()
    local default = {
        AntiAFK = true,
        AutoRejoin = true,
        AutoJump = false,
        AntiStuck = true,
        TeleportLoop = false,
        TeleportPoint = {x = 0, y = 100, z = 0},
        TeleportDelay = 0.5,
        Fly = false,
        NoClip = false,
        RejoinSource = "https://raw.githubusercontent.com/choalne02-dotcom/StealAUGC/refs/heads/main/rejoinScriptByQuang",
        ExecuteThisScript = "",
        AutoHopServer = false,
        AutoHopDelay = 300,
        AutoRejoinTimer = false,
        AutoRejoinTimerDelay = 300,
        LoopExecute = false,
        LoopExecuteDelay = 5,
        UseUserOnly = false
    }
    
    local target = FILENAME
    if is_file(FILENAME) then
        local s, decoded = pcall(HttpService.JSONDecode, HttpService, read_file(FILENAME))
        if s and decoded.UseUserOnly and is_file(USER_FILENAME) then target = USER_FILENAME end
    end

    if is_file(target) then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, read_file(target))
        if success and type(decoded) == "table" then 
            for k, v in pairs(decoded) do default[k] = v end
        end
    end
    getgenv().Config = default
end

local function SaveConfig()
    pcall(function()
        local data = HttpService:JSONEncode(getgenv().Config)
        write_file(FILENAME, data)
        if getgenv().Config.UseUserOnly then write_file(USER_FILENAME, data) end
    end)
end

LoadConfig()

-- Hàm thực thi linh hoạt: hỗ trợ URL hoặc Script thô
local function UniversalExecute(source)
    if source == "" then return end
    local code = ""
    if source:match("^http") then
        local s, res = pcall(game.HttpGet, game, source)
        if s then code = res end
    else
        code = source
    end
    
    if code ~= "" then
        local func, err = loadstring(code)
        if func then 
            task.spawn(func) 
        else 
            warn("Execute Error: " .. tostring(err)) 
        end
    end
end

local function HopServer()
    local PlaceID = game.PlaceId
    local JobID = game.JobId
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if success then
        for _, server in pairs(result.data) do
            if server.playing < server.maxPlayers and server.id ~= JobID then
                TeleportService:TeleportToPlaceInstance(PlaceID, server.id, lp)
                break
            end
        end
    end
end

