if getgenv().Config.AutoRejoin then
    local QueueOnTeleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    if QueueOnTeleport then
        pcall(function()
            local rSrc = getgenv().Config.RejoinSource
            local eSrc = getgenv().Config.ExecuteThisScript
            if rSrc ~= "" then
                local code = rSrc:match("^http") and "loadstring(game:HttpGet('"..rSrc.."'))()" or rSrc
                QueueOnTeleport(code)
            end
            if eSrc ~= "" then
                local code = eSrc:match("^http") and "loadstring(game:HttpGet('"..eSrc.."'))()" or eSrc
                QueueOnTeleport(code)
            end
        end)
    end
    GuiService.ErrorMessageChanged:Connect(function() task.wait(0.5) TeleportService:Teleport(game.PlaceId, lp) end)
end

