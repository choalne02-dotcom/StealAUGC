-- BIẾN KIỂM SOÁT MENU LOAD (Để thực hiện Toggle)
local activeLoadMenu = nil 
local activeRenameFrame = nil

local function showLoadMenu()
    if activeLoadMenu then
        activeLoadMenu:Destroy()
        activeLoadMenu = nil
        return
    end

    local loadMenu = Instance.new("Frame", sg)
    activeLoadMenu = loadMenu 
    
    loadMenu.Size = UDim2.new(0, 250, 0, 300)
    loadMenu.Position = UDim2.new(0.5, -125, 0.5, -150)
    loadMenu.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    loadMenu.Active, loadMenu.Draggable = true, true
    Instance.new("UICorner", loadMenu)
    
    loadMenu.AncestryChanged:Connect(function()
        if not loadMenu:IsDescendantOf(game) then activeLoadMenu = nil end
    end)

    local title = Instance.new("TextLabel", loadMenu)
    title.Size, title.BackgroundColor3, title.Text, title.TextColor3 = UDim2.new(1, 0, 0, 30), Color3.fromRGB(35, 35, 35), "SELECT CONFIG", Color3.new(1, 1, 1)
    
    local closeBtn = Instance.new("TextButton", loadMenu)
    closeBtn.Size, closeBtn.Position, closeBtn.Text, closeBtn.TextColor3, closeBtn.BackgroundTransparency = UDim2.new(0, 30, 0, 30), UDim2.new(1, -30, 0, 0), "X", Color3.new(1, 0, 0), 1
    closeBtn.MouseButton1Click:Connect(function() loadMenu:Destroy(); activeLoadMenu = nil end)
    
    local listSc = Instance.new("ScrollingFrame", loadMenu)
    listSc.Size, listSc.Position, listSc.BackgroundTransparency, listSc.ScrollBarThickness = UDim2.new(1, -10, 1, -40), UDim2.new(0, 5, 0, 35), 1, 2
    local listLy = Instance.new("UIListLayout", listSc)
    listLy.Padding = UDim.new(0, 5)

    local function refreshFiles()
        for _, v in pairs(listSc:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        local files = listfiles("")
        for _, file in pairs(files) do
            if file:find(tostring(game.PlaceId)) and file:find(".json") then
                local row = Instance.new("Frame", listSc);
                row.Size = UDim2.new(1, 0, 0, 30); row.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                local name = file:gsub(tostring(game.PlaceId).."_", ""):gsub(".json", "")
                
                local nameBtn = Instance.new("TextButton", row);
                nameBtn.Size, nameBtn.Position, nameBtn.Text, nameBtn.TextColor3, nameBtn.BackgroundTransparency, nameBtn.TextXAlignment = UDim2.new(1, -70, 1, 0), UDim2.new(0, 5, 0, 0), name, Color3.new(1, 1, 1), 1, 0
                nameBtn.MouseButton1Click:Connect(function()
                    local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(file)) end)
                    if success then
                        s = decoded.settings
                        sd_box.Text, td_box.Text, tool_d_box.Text = tostring(s.sd), tostring(s.td), tostring(s.tool_d)
                        d = { R={}, P={}, C={}, T={}, TP={}, ET={}, AT={} }
                        local function deserialize(src, target)
                            for _, v in pairs(src) do
                                local item = {blocked = v.blocked, time = v.time}
                                if v.path then 
                                    local obj = getInstanceFromPath(v.path)
                                    if obj then if v.m then item.o = obj; item.m = v.m; item.a = v.a; item.txt = v.txt else item.obj = obj end end
                                elseif v.cf then item.obj = CFrame.new(unpack(v.cf)) end
                                if item.o or item.obj then table.insert(target, item) end
                            end
                        end
                        deserialize(decoded.data.R, d.R);
                        deserialize(decoded.data.P, d.P); deserialize(decoded.data.C, d.C)
                        deserialize(decoded.data.T, d.T);
                        deserialize(decoded.data.TP, d.TP); deserialize(decoded.data.ET, d.ET); deserialize(decoded.data.AT, d.AT)
                        
                        updateUIStates()
                        ref();
                        notify("System", "Loaded: "..name); 
                        loadMenu:Destroy(); activeLoadMenu = nil
                    end
                end)
                
                local delBtn = Instance.new("TextButton", row);
                delBtn.Size, delBtn.Position, delBtn.Text, delBtn.BackgroundColor3 = UDim2.new(0, 25, 0, 25), UDim2.new(1, -30, 0, 2), "❌", Color3.fromRGB(80, 0, 0)
                delBtn.MouseButton1Click:Connect(function() delfile(file); refreshFiles() end)
                
                local editBtn = Instance.new("TextButton", row);
                editBtn.Size, editBtn.Position, editBtn.Text, editBtn.BackgroundColor3 = UDim2.new(0, 25, 0, 25), UDim2.new(1, -60, 0, 2), "✍️", Color3.fromRGB(40, 40, 40)
                editBtn.MouseButton1Click:Connect(function() 
                    -- Sửa lỗi: Nếu đang có bảng Rename khác thì xóa đi
                    if activeRenameFrame then activeRenameFrame:Destroy() end
                    
                    local eFrame = Instance.new("Frame", sg); eFrame.Size = UDim2.new(0, 250, 0, 100); eFrame.Position = UDim2.new(0.5, -125, 0.5, -50); eFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30); eFrame.Active = true; eFrame.Draggable = true; Instance.new("UICorner", eFrame)
                    activeRenameFrame = eFrame
                    
                    local eTitle = Instance.new("TextLabel", eFrame); eTitle.Size = UDim2.new(1, 0, 0, 30); eTitle.Text = "RENAME CONFIG"; eTitle.TextColor3 = Color3.new(1, 1, 1); eTitle.BackgroundTransparency = 1
                    local eBox = Instance.new("TextBox", eFrame); eBox.Size = UDim2.new(0, 200, 0, 30); eBox.Position = UDim2.new(0.5, -100, 0.4, 0); eBox.Text = name; eBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45); eBox.TextColor3 = Color3.new(1, 1, 1)
                    local eSave = Instance.new("TextButton", eFrame);
                    eSave.Size = UDim2.new(0, 80, 0, 25); eSave.Position = UDim2.new(0.5, -40, 0.75, 0); eSave.Text = "RENAME"; eSave.BackgroundColor3 = Color3.fromRGB(0, 120, 200);
                    eSave.TextColor3 = Color3.new(1, 1, 1)
                    eSave.MouseButton1Click:Connect(function()
                        if eBox.Text ~= "" and eBox.Text ~= name then
                            local oldFile = file
                            local newFile = game.PlaceId .. "_" .. eBox.Text .. ".json"
                            local content = readfile(oldFile)
                            writefile(newFile, content)
                            delfile(oldFile)
                            notify("System", "Renamed config!")
                            eFrame:Destroy(); activeRenameFrame = nil; refreshFiles()
                        end
                    end)
                    local eClose = Instance.new("TextButton", eFrame);
                    eClose.Size = UDim2.new(0, 20, 0, 20); eClose.Position = UDim2.new(1, -25, 0, 5); eClose.Text = "X"; eClose.TextColor3 = Color3.new(1, 0, 0);
                    eClose.BackgroundTransparency = 1
                    eClose.MouseButton1Click:Connect(function() eFrame:Destroy(); activeRenameFrame = nil end)
                end)
            end
        end
        listSc.CanvasSize = UDim2.new(0, 0, 0, listLy.AbsoluteContentSize.Y)
    end
    refreshFiles()
end

