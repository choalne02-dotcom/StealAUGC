function ref()
    for _,v in pairs(sc:GetChildren())do if v:IsA("Frame")then v:Destroy()end end
    st.Text=("R:%d | P:%d | C:%d | T:%d | TP:%d | ET:%d | AT:%d"):format(#d.R,#d.P,#d.C,#d.T,#d.TP,#d.ET,#d.AT)
    
    local allItems = {}
    local function collect(tab, labelType)
        for i, v in ipairs(tab) do
            local dName, fPath, rObj = "", "nil", nil
            if labelType == "R" then 
                rObj = v.o;
                dName = "R: "..(rObj and rObj.Name or "Unknown").." "..(v.m == "InvokeServer" and "(F)" or "(E)").." ["..(v.txt or "").."]"
                fPath = "Path: "..getSafePath(rObj).." | Args: {"..(v.txt or "").."}"
            elseif labelType == "P" or labelType == "C" or labelType == "T" or labelType == "ET" or labelType == "AT" then 
                rObj = v.obj;
                dName = labelType..": "..(rObj and rObj.Name or "Unknown"); fPath = "Path: "..getSafePath(rObj)
            elseif labelType == "TP" then 
                local p = typeof(v.obj) == "CFrame" and v.obj.Position or v.obj
                dName = ("TP: %.1f, %.1f, %.1f"):format(p.X, p.Y, p.Z);
                rObj = v.obj; fPath = "Position: "..tostring(p)
            end
            if not v.time then v.time = tick() end
            table.insert(allItems, {txt = dName, tab = tab, idx = i, blocked = v.blocked, path = fPath, obj = rObj, lType = labelType, t = v.time})
        end
    end
    collect(d.R, "R");
    collect(d.P, "P"); collect(d.C, "C"); collect(d.T, "T"); collect(d.TP, "TP"); collect(d.ET, "ET");
    collect(d.AT, "AT")
    
    table.sort(allItems, function(a, b) return a.t < b.t end)
    for i, item in ipairs(allItems) do item.finalID = i end
    table.sort(allItems, function(a, b)
        if a.blocked ~= b.blocked then return not a.blocked end
        return a.t > b.t
    end)
    for _, item in ipairs(allItems) do createRow(item.txt, item.tab, item.idx, item.blocked, item.path, item.obj, item.lType, item.finalID) end
    sc.CanvasSize=UDim2.new(15,0,0,#sc:GetChildren()*30)
end

