    })
end

local function tableToString(t)
    local str = ""
    if type(t) ~= "table" then return tostring(t) end
    for k,v in pairs(t) do
        local val = tostring(v)
        if type(v) == "table" then val = "{...}" elseif type(v) == "userdata" then val = v.Name end
        if #val > 12 then val = val:sub(1,10)..".." end
        str = str .. "["..tostring(k).."]:"..val..", "
    end
    return str ~= "" and str:sub(1, #str-2) or "{}"
end

local function getSafePath(obj)
    if not obj then return "nil" end
    local success, path = pcall(function()
        local parts = {}
        local curr = obj
        while curr and curr ~= game do
            local name = curr.Name
            local safeName = name:gsub('"', '\\"')
            table.insert(parts, 1, '["' .. safeName .. '"]')
            curr = curr.Parent
        end
        return "game" .. table.concat(parts)
    end)
    return success and path or "nil"
end

local function getInstanceFromPath(path)
    local success, obj = pcall(function()
        local parts = path:split('["')
        local current = game
        for i=2, #parts do
            local name = parts[i]:split('"]')[1]
            current = current:FindFirstChild(name)
        end
        return current
    end)
    return success and obj or nil
end

