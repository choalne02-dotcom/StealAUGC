local saveBtn = btn("SAVE", UDim2.new(0, 125, 0, 147), Color3.fromRGB(0, 100, 50), function()
    local name = configName.Text ~= "" and configName.Text or "Default"
    local fileName = game.PlaceId .. "_" .. name .. ".json"
    
    local saveData = {
        settings = s,
        data = { R={}, P={}, C={}, T={}, TP={}, ET={}, AT={} }
    }
    
    local function serialize(tab, target)
        for _, v in pairs(tab) do
            local item = {blocked = v.blocked, time = v.time}
            if v.o then item.path = getSafePath(v.o);
                item.m = v.m; item.a = v.a; item.txt = v.txt
            elseif v.obj then
                if typeof(v.obj) == "CFrame" then item.cf = {v.obj:GetComponents()}
                else item.path = getSafePath(v.obj) end
            end
            table.insert(target, item)
        end
    end
    
    serialize(d.R, saveData.data.R); serialize(d.P, saveData.data.P);
    serialize(d.C, saveData.data.C)
    serialize(d.T, saveData.data.T);
    serialize(d.TP, saveData.data.TP); serialize(d.ET, saveData.data.ET);
    serialize(d.AT, saveData.data.AT)

    writefile(fileName, HttpService:JSONEncode(saveData))
    notify("System", "Saved config: " .. fileName)
end)
