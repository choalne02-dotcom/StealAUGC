-- [[ HOOKS ]]
local mt=getrawmetatable(game);
setreadonly(mt,false); local old=mt.__namecall
mt.__namecall=newcclosure(function(self,...)
    local m, a = getnamecallmethod(), {...}
    if s.hook_enabled and (m=="FireServer" or m=="InvokeServer") and not checkcaller() then
        if not tostring(self):find("Chat") and not tostring(self):find("Report") then
            local currentArgsTxt = ketamine_to_string(a); local ex = false
            for _,v in pairs(d.R) do if (v.o == self and ketamine_to_string(v.a) == currentArgsTxt) then ex = true break end end
            if not ex then table.insert(d.R, {o = self, a = a, m = m, txt = tableToString(a), blocked = false, time = tick()}) end
        end
    end
    return old(self,...)
end);
setreadonly(mt,true)

local function hookTool(tool)
    if not tool:IsA("Tool") then return end
    tool.Equipped:Connect(function()
        if not s.hook_enabled then return end
        local ex = false; for _,v in pairs(d.ET) do if v.obj == tool then ex = true break end end
        if not ex then table.insert(d.ET, {obj = tool, blocked = false, time = tick()}); ref() end
    end)
    tool.Activated:Connect(function()
        if not s.hook_enabled then return end
        local ex = false; for _,v in pairs(d.AT) do if v.obj == tool then ex = true break end end
        if not ex then table.insert(d.AT, {obj = tool, blocked = false, time = tick()}); ref() end
    end)
end
lp.Backpack.ChildAdded:Connect(hookTool)
if lp.Character then lp.Character.ChildAdded:Connect(hookTool) end
for _,v in pairs(lp.Backpack:GetChildren()) do hookTool(v) end

task.spawn(function() while task.wait(0.5) do local total = #d.R+#d.P+#d.C+#d.T+#d.TP+#d.ET+#d.AT; if total ~= lastRemCount then lastRemCount = total; ref() end end end)

O.PromptTriggered:Connect(function(p,pl) 
    if s.hook_enabled and pl==lp then 
        local ex=false; for _,v in pairs(d.P) do if getVal(v)==p then ex=true break end end; 
        if not ex then table.insert(d.P,{obj=p, blocked=false, time = tick()}); ref() end 
    end 
end)

lp:GetMouse().Button1Down:Connect(function()
    if not s.hook_enabled then return end
    local t=lp:GetMouse().Target; if not t then return end
    local c=t:FindFirstChildOfClass("ClickDetector") or (t.Parent and t.Parent:FindFirstChildOfClass("ClickDetector"))
    if c then local ex=false; for _,v in pairs(d.C) do if getVal(v)==c then ex=true break end end; if not ex then table.insert(d.C,{obj=c, blocked=false, time = tick()}); ref() end end
end)

local function tr(v)
    if v:IsA("BasePart") and v:FindFirstChildOfClass("TouchTransmitter") then
        v.Touched:Connect(function(h) 
            if s.hook_enabled and h.Parent==lp.Character then 
                local ex=false; for _,obj in pairs(d.T) do if getVal(obj)==v then ex=true break end end;
                if not ex then table.insert(d.T,{obj=v, blocked=false, time = tick()}); ref() end 
            end 
        end)
    end
end
workspace.DescendantAdded:Connect(tr);
for _,v in pairs(workspace:GetDescendants()) do tr(v) end

-- [SYSTEM LOOPS]
task.spawn(function()
    while task.wait() do 
        if s.lp then 
            local iterations = 1
            local delay = 0
            local val = tostring(s.sd)
            
            if val:sub(1,1) == "x" then
                iterations = tonumber(val:sub(2)) or 1
                delay = 0
            else
                delay = tonumber(val) or 0
            end

            pcall(function()
                for i = 1, iterations do
                    for _,v in pairs(d.R) do if not v.blocked and v.o then if v.m=="FireServer" then v.o:FireServer(unpack(v.a)) else task.spawn(function() v.o:InvokeServer(unpack(v.a)) end) end end end
                    for _,v in pairs(d.P) do if not v.blocked and v.obj and v.obj.Parent then fireproximityprompt(v.obj) end end
                    for _,v in pairs(d.C) do if not v.blocked and v.obj and v.obj.Parent then fireclickdetector(v.obj) end end
                    for _,v in pairs(d.T) do if not v.blocked and v.obj and v.obj.Parent and lp.Character:FindFirstChild("HumanoidRootPart") then firetouchinterest(lp.Character.HumanoidRootPart,v.obj,0);firetouchinterest(lp.Character.HumanoidRootPart,v.obj,1) end end
                end
            end); 
            task.wait(delay)
        else task.wait(0.5) end
    end
end)

task.spawn(function()
    while task.wait() do
        if s.et or s.at then
            pcall(function()
                if s.et then for _,v in pairs(d.ET) do if not v.blocked and v.obj and v.obj.Parent and lp.Character:FindFirstChild("Humanoid") then lp.Character.Humanoid:EquipTool(v.obj) end end end
                if s.at then for _,v in pairs(d.AT) do if not v.blocked and v.obj and v.obj.Parent then v.obj:Activate() end end end
            end);
            task.wait(s.tool_d)
        else task.wait(0.5) end
    end
end)

task.spawn(function()
    while task.wait() do 
        if s.atp and #d.TP>0 then
            for _,v in ipairs(d.TP) do 
                if not s.atp then break end
                if not v.blocked and v.obj then if lp.Character then lp.Character:PivotTo(typeof(v.obj) == "CFrame" and v.obj or CFrame.new(v.obj)) end; task.wait(s.td) end
            end
        else task.wait(0.5) end
    end
end)

