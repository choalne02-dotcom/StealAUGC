-- [[ KETAMINE SERIALIZER ]]
local function ketamine_to_string(v)
    if type(v) == "table" then
        local res = "{"
        local first = true
        for i, val in pairs(v) do 
            if not first then res = res .. "," end
            res = res .. "[" .. ketamine_to_string(i) .. "]=" .. ketamine_to_string(val)
            first = false
        end
        return res .. "}"
    elseif type(v) == "string" then return '"' .. v .. '"'
    elseif type(v) == "userdata" then 
        local success, name = pcall(function() return v:GetFullName() end)
        return success and "game." .. tostring(name) or '"Unknown Userdata"'
    else return tostring(v) end
end

